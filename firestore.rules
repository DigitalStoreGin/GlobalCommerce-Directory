rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──────────────────────────────────────────────
    match /users/{userId} {
      // Only the authenticated user can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ── Favorites sub-collection ──────────────────────────────────
      match /favorites/{favId} {
        // Only the authenticated user can read/write their own favorites
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Validate favorite document fields on create/update
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasAll(['id', 'n', 'url'])
          && request.resource.data.id is string
          && request.resource.data.n is string
          && request.resource.data.url is string;
      }
    }

    // ── Default: deny everything else ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
